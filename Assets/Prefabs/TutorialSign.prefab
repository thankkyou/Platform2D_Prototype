--- !u!114 &568662912114155455
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4156627825878252502}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 722d2488d61ff824d9ed8c7dcb7dffb7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  dialogue:
    dialogueLines:
    - character:
        name: "B\u1EA3ng h\u01B0\u1EDBng d\u1EABn"
      line: "Xin ch\xE0o l\u1EEF kh\xE1ch ph\u01B0\u01A1ng xa \u0111\xE3 \u0111\u1EB7t
        ch\xE2n t\u1EDBi khu r\u1EEBng y\xEAn b\xECnh. N\u01A1i \u0111\xE2y b\xECnh
        d\u1ECB nh\u01B0ng v\u1EABn ch\u1EE9a nh\u1EEFng nguy hi\u1EC3m r\xECnh r\u1EADp.  "
    - character:
        name: "B\u1EA3ng h\u01B0\u1EDBng d\u1EABn"
      line: "\u0110\u1EC3 v\u01B0\u1EE3t kh\u1ECFi khu r\u1EEBng n\xE0y, h\xE3y l\xE0m
        theo ch\u1EC9 d\u1EABn v\xE0 \u0111\u1EC3 \xFD nh\u1EEFng c\u1EA3nh v\u1EADt
        xung quanh \u0111\u1EC3 t\xECm l\u1ED1i tho\xE1t"
    - character:
        name: "B\u1EA3ng h\u01B0\u1EDBng d\u1EABn"
      line: "\u0110\u1EA7u ti\xEAn l\xE0 ph\u1EA7n c\u01A1 b\u1EA3n nh\u1EA5t. Ng\u01B0\u01A1i
        c\xF3 th\u1EC3 s\u1EED d\u1EE5ng ph\xEDm:\nA \u0111\u1EC3 di chuy\u1EC3n
        sang tr\xE1i\nD \u0111\u1EC3 di chuy\u1EC3n sang ph\u1EA3i"
